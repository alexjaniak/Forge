# ── GitHub auth ───────────────────────────────────────────────
# From `gh auth token`
GH_TOKEN=

# ── Innies proxy (recommended) ───────────────────────────────
# Routes claude/codex API calls through the innies proxy.
# Requires: npm install -g innies
USE_INNIES=true
INNIES_TOKEN=in_live_...

# ── Agent runtime ────────────────────────────────────────────
# "claude" (default) or "codex"
# Claude requires: npm install -g @anthropic-ai/claude-code
# Codex requires: npm install -g @openai/codex
# AGENT_RUNTIME=codex

# ── Direct auth (only needed if USE_INNIES=false) ────────────
# Claude CLI auth (from `claude setup-token`)
# CLAUDE_CODE_OAUTH_TOKEN="sk-ant-oat01-..."
#
# Codex CLI auth
# OPENAI_API_KEY="sk-..."
#
# Optional: override claude binary path
# CLAUDE_BIN="/path/to/claude"

# ── Limits ───────────────────────────────────────────────────
# Max runtime in seconds (default: 1200 = 20 minutes)
# MAX_RUNTIME=1200
